<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – IoT Network Recommender</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; font-size: 0.93rem; }
        .navbar-brand { font-weight: 600; letter-spacing: 0.03em; }
        .page-header { border-bottom: 2px solid #dee2e6; padding-bottom: 0.5rem; margin-bottom: 1.5rem; }
        .step-badge { font-size: 0.75rem; padding: 0.25em 0.6em; vertical-align: middle; }
        .card { box-shadow: 0 1px 4px rgba(0,0,0,.06); }
        .table th { background-color: #f1f3f5; font-weight: 600; }
        .metric-box { background: #fff; border: 1px solid #dee2e6; border-radius: 6px; padding: 1rem; text-align: center; }
        .metric-box .value { font-size: 1.5rem; font-weight: 700; }
        .winner-badge { font-size: 1.1rem; background: #d1e7dd; border: 1px solid #a3cfbb; padding: 0.75rem 1.25rem; border-radius: 6px; }
        .phase-nav .nav-link { color: #495057; }
        .phase-nav .nav-link.active { font-weight: 600; color: #0d6efd; }
        .phase-nav .nav-link.done { color: #198754; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                IoT Network Recommender
            </a>
            <span class="navbar-text text-secondary small">Master's Thesis Research Prototype</span>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
